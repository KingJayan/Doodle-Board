#!/bin/sh

COMMIT_MSG_FILE=$1

TYPE=$(tail -n 1 "$COMMIT_MSG_FILE" | awk '{print $NF}' | tr '[:upper:]' '[:lower:]')

if [ "$TYPE" = "patch" ] || [ "$TYPE" = "minor" ] || [ "$TYPE" = "major" ]; then
  echo "bump detected, $TYPE..."
  
  npm version "$TYPE" --no-git-tag-version
  
  bun -e "const fs = require('fs'); let r = fs.readFileSync('README.md','utf8'); const v = require('./package.json').version; r = r.replace(/(version: |version-)\d+\.\d+\.\d+/g, '\\\$1' + v); fs.writeFileSync('README.md', r);"

  VERSION=$(node -p "require('./package.json').version")
  FILE="src/components/settings-modal/settings-modal.component.ts"
  node -e "const fs=require('fs'),v='$VERSION',f='$FILE';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(/const version = '[^']*';/,\"const version = '\"+v+\"';\"));"

  git add package.json README.md "$FILE"
  [ -f package-lock.json ] && git add package-lock.json
  [ -f bun.lockb ] && git add bun.lockb

  git commit --no-verify --no-edit -F "$COMMIT_MSG_FILE"
fi

exit 0
